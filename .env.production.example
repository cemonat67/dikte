APP_ENV=production
DOMAIN=zerotrust.example.com
LETSENCRYPT_EMAIL=admin@example.com

DATABASE_URL=postgresql://zerotrust:YOUR_SECURE_PASSWORD@postgres:5432/zerotrust
CORS_ORIGINS=https://zerotrust.example.com
API_PREFIX=/api/v1
TRUST_TICK_SECONDS=10

ADMIN_API_KEY=replace-with-long-random-secret
JWT_SECRET_KEY=replace-with-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production
WEBHOOK_SECRET=replace-with-long-random-secret

POSTGRES_USER=zerotrust
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD
POSTGRES_DB=zerotrust
